<Window x:Class="ADB_Tool_Automation_Post_FB.UI.DeviceDiagnosticWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IKAutomation - Farm Control"
        Width="1080" Height="780"
        MinWidth="920" MinHeight="680"
        Background="#FFF4F7FB"
        FontFamily="Segoe UI" FontSize="13"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FF172033"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF64748B"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#FFE2E8F0"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#FF2563EB"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="CaptionStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="#FFCBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FFF8FAFC"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.72"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FFE2E8F0"/>
                                <Setter Property="Foreground" Value="#FF94A3B8"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Foreground" Value="#FF334155"/>
            <Setter Property="Background" Value="#FFF1F5F9"/>
            <Setter Property="Padding" Value="11,6"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <Style x:Key="ContinuousButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#FF0F766E"/>
        </Style>

        <Style x:Key="RetryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#FFD97706"/>
        </Style>

        <Style x:Key="StopButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#FFDC2626"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Infinity Kingdom Farm Control"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="24" FontWeight="Bold"/>
                <TextBlock Text="Quản lý thiết bị, farm liên tục và theo dõi sức khỏe trong một màn hình."
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            <Border Grid.Column="1" Background="#FFDBEAFE" CornerRadius="14"
                    Padding="12,6" VerticalAlignment="Center">
                <TextBlock Text="Tối đa 20 thiết bị" Foreground="#FF1D4ED8"
                           FontWeight="SemiBold"/>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="410"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Thiết bị" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Chọn các LDPlayer sẽ tham gia phiên chạy."
                                               Style="{StaticResource CaptionStyle}" Margin="0,3,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Làm mới"
                                        Click="RefreshDevices_Click"
                                        Style="{StaticResource SecondaryButtonStyle}"/>
                            </Grid>

                            <ListBox x:Name="DeviceSelectionListBox" Height="210"
                                     BorderThickness="0" Background="Transparent"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FFF8FAFC" BorderBrush="#FFE2E8F0"
                                                BorderThickness="1" CornerRadius="6"
                                                Padding="10,8" Margin="0,3">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox IsChecked="{Binding IsSelected}"
                                                          Content="{Binding DeviceName}"
                                                          FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Status}"
                                                           Foreground="#FF475569"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="145"
                                                           ToolTip="{Binding Status}"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <WrapPanel Margin="0,10,0,0">
                                <Button Content="Chọn tất cả" Click="SelectAllDevices_Click"
                                        Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                                <Button Content="Bỏ chọn" Click="ClearDeviceSelection_Click"
                                        Style="{StaticResource SecondaryButtonStyle}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border x:Name="OneShotFarmResourcesGroupBox"
                            Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Cấu hình farm" Style="{StaticResource CardTitleStyle}"/>
                            <TextBlock Text="Chọn ít nhất hai loại tài nguyên để hệ thống luân phiên."
                                       Style="{StaticResource CaptionStyle}" Margin="0,3,0,12"/>
                            <WrapPanel Margin="0,0,0,10">
                                <CheckBox x:Name="IronResourceCheckBox" Content="Sắt" Margin="0,0,18,8"/>
                                <CheckBox x:Name="StoneResourceCheckBox" Content="Mỏ đá" Margin="0,0,18,8"/>
                                <CheckBox x:Name="WoodResourceCheckBox" Content="Rừng" Margin="0,0,18,8"/>
                                <CheckBox x:Name="FoodResourceCheckBox" Content="Đất nông nghiệp" Margin="0,0,0,8"/>
                            </WrapPanel>
                            <Expander Header="Thiết lập nâng cao" IsExpanded="False"
                                      Foreground="{StaticResource TextPrimaryBrush}">
                                <StackPanel Margin="0,10,0,0">
                                    <Border Background="#FFF8FAFC" BorderBrush="#FFE2E8F0"
                                            BorderThickness="1" CornerRadius="7" Padding="10">
                                        <StackPanel>
                                            <TextBlock Text="Chiến lược tìm kiếm"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="Thử lần lượt từ trái sang phải; cấp hoặc đội không có trên thiết bị sẽ được bỏ qua."
                                                       Style="{StaticResource CaptionStyle}"
                                                       TextWrapping="Wrap" Margin="0,3,0,10"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="125"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Text="Thứ tự cấp"
                                                           Style="{StaticResource CaptionStyle}"
                                                           ToolTip="Danh sách cấp tài nguyên, cách nhau bằng dấu phẩy."/>
                                                <TextBox x:Name="LevelPriorityTextBox" Grid.Column="1"
                                                         Text="7,6,5" Style="{StaticResource InputStyle}"
                                                         Margin="0,0,0,7"
                                                         ToolTip="Ví dụ: 7,6,5. Hỗ trợ cấp 1 đến 30, không lặp."/>
                                                <TextBlock Grid.Row="1" Text="Thứ tự đội"
                                                           Style="{StaticResource CaptionStyle}"
                                                           ToolTip="Danh sách đội được phép dùng, theo thứ tự ưu tiên."/>
                                                <TextBox x:Name="TeamPriorityTextBox" Grid.Row="1" Grid.Column="1"
                                                         Text="4,3,2" Style="{StaticResource InputStyle}"
                                                         ToolTip="Ví dụ: 4,3,2,1. Chỉ các đội có trong danh sách mới được dùng."/>
                                            </Grid>
                                            <TextBlock Text="Thêm số 1 vào danh sách nếu muốn dùng Đội 1."
                                                       Foreground="#FF1D4ED8" FontSize="12"
                                                       Margin="125,6,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#FFF8FAFC" BorderBrush="#FFE2E8F0"
                                            BorderThickness="1" CornerRadius="7" Padding="10"
                                            Margin="0,8,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Lịch chờ đội"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="Chỉ áp dụng khi chưa có đội phù hợp đang sẵn sàng."
                                                       Style="{StaticResource CaptionStyle}"
                                                       TextWrapping="Wrap" Margin="0,3,0,10"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="125"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Text="Kiểm tra lại sau"
                                                           Style="{StaticResource CaptionStyle}"/>
                                                <TextBox x:Name="ReadyCheckIntervalTextBox" Grid.Column="1"
                                                         Text="15" Style="{StaticResource InputStyle}"
                                                         Margin="0,0,0,7"
                                                         ToolTip="Số phút giữa hai lần kiểm tra, từ 1 đến 1440."/>
                                                <TextBlock Grid.Row="1" Text="Chờ tối đa"
                                                           Style="{StaticResource CaptionStyle}"/>
                                                <TextBox x:Name="ReadyMaxWaitTextBox" Grid.Row="1" Grid.Column="1"
                                                         Text="12" Style="{StaticResource InputStyle}"
                                                         ToolTip="Tổng số giờ chờ tối đa, từ 1 đến 168."/>
                                            </Grid>
                                            <TextBlock Text="Đơn vị: phút cho chu kỳ kiểm tra, giờ cho thời gian chờ tối đa."
                                                       Style="{StaticResource CaptionStyle}"
                                                       FontSize="12" Margin="125,6,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Expander>

                            <WrapPanel Margin="0,12,0,0">
                                <Button Content="Lưu cấu hình" Click="SaveFarmSettings_Click"
                                        Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                                <Button Content="Khôi phục mặc định" Click="RestoreFarmDefaults_Click"
                                        Style="{StaticResource SecondaryButtonStyle}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Button x:Name="RunOneShotFarmButton" Content="Chạy thiết bị đã chọn"
                                Click="RunOneShotFarm_Click" Style="{StaticResource BaseButtonStyle}"/>
                        <Button x:Name="RunContinuousFarmButton" Grid.Column="2" Content="Chạy liên tục"
                                Click="RunContinuousFarm_Click" Style="{StaticResource ContinuousButtonStyle}"/>
                        <Button x:Name="RetryFailedDevicesButton" Grid.Row="2" Content="Chạy lại thiết bị lỗi"
                                Click="RetryFailedDevices_Click" Style="{StaticResource RetryButtonStyle}"
                                IsEnabled="False"/>
                        <Button x:Name="StopOneShotFarmButton" Grid.Row="2" Grid.Column="2" Content="Dừng"
                                Click="StopOneShotFarm_Click" Style="{StaticResource StopButtonStyle}"
                                IsEnabled="False"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="3*"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="2*"/>
                </Grid.RowDefinitions>

                <Border Style="{StaticResource CardStyle}">
                    <Expander IsExpanded="True">
                        <Expander.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Sức khỏe hệ thống" Style="{StaticResource CardTitleStyle}"/>
                                <Border Grid.Column="1" Background="#FFEFF6FF" CornerRadius="10"
                                        Padding="9,4" Margin="16,0,0,0">
                                    <TextBlock x:Name="HealthOverviewTextBlock" Text="Idle"
                                               Foreground="#FF1D4ED8" FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                        </Expander.Header>
                        <Grid Margin="20,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="135"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="125"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/><RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Trạng thái thiết bị" Style="{StaticResource CaptionStyle}"/>
                            <TextBlock x:Name="HealthStatesTextBlock" Grid.Row="0" Grid.Column="1"
                                       Text="-" Style="{StaticResource ValueStyle}" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Lỗi / ổ đĩa" Style="{StaticResource CaptionStyle}"/>
                            <TextBlock x:Name="HealthPressureTextBlock" Grid.Row="0" Grid.Column="3"
                                       Text="-" Style="{StaticResource ValueStyle}"/>
                            <TextBlock Grid.Row="1" Text="Tải thích ứng" Style="{StaticResource CaptionStyle}"/>
                            <TextBlock x:Name="HealthLoadTextBlock" Grid.Row="1" Grid.Column="1"
                                       Text="-" Style="{StaticResource ValueStyle}"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Uptime" Style="{StaticResource CaptionStyle}"/>
                            <TextBlock x:Name="HealthUptimeTextBlock" Grid.Row="1" Grid.Column="3"
                                       Text="00:00:00" Style="{StaticResource ValueStyle}"/>
                            <TextBlock Grid.Row="2" Text="Heartbeat gần nhất" Style="{StaticResource CaptionStyle}"/>
                            <TextBlock x:Name="HealthHeartbeatTextBlock" Grid.Row="2" Grid.Column="1"
                                       Grid.ColumnSpan="3" Text="-" Style="{StaticResource ValueStyle}"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </Expander>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                    <Expander IsExpanded="True">
                        <Expander.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Tiến trình farm" Style="{StaticResource CardTitleStyle}"/>
                                <Border Grid.Column="1" Background="#FFEFF6FF" CornerRadius="10"
                                        Padding="9,4" Margin="16,0,0,0">
                                    <TextBlock x:Name="ProgressOverviewTextBlock" Text="Idle"
                                               Foreground="#FF1D4ED8" FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                        </Expander.Header>
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="FarmProgressItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Expander IsExpanded="True" Margin="0,0,0,8">
                                            <Expander.Header>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding DeviceName}" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Stage}"
                                                               Foreground="#FF1D4ED8" Margin="18,0,0,0"/>
                                                </Grid>
                                            </Expander.Header>
                                            <Border Background="#FFF8FAFC" BorderBrush="#FFE2E8F0"
                                                    BorderThickness="1" CornerRadius="7"
                                                    Padding="10" Margin="20,6,0,0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="5*"/>
                                                        <ColumnDefinition Width="16"/>
                                                        <ColumnDefinition Width="4*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Message}" TextWrapping="Wrap"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                                        <TextBlock Text="{Binding Detail}" Margin="0,6,0,0"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding Schedule}" Margin="0,8,0,0"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <ItemsControl Grid.Column="2" ItemsSource="{Binding Teams}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="0,2">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="75"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Text="{Binding TeamName}"
                                                                               FontWeight="SemiBold"/>
                                                                    <TextBlock Grid.Column="1" Text="{Binding Status}"
                                                                               Foreground="{Binding StatusBrush}"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Grid>
                                            </Border>
                                        </Expander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                    </Expander>
                </Border>

                <Border Grid.Row="4" Style="{StaticResource CardStyle}">
                    <Expander Header="Chi tiết lần chạy gần nhất" IsExpanded="True"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              FontWeight="SemiBold">
                        <ScrollViewer Margin="20,10,0,0" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                            <TextBlock x:Name="StatusTextBlock" Text="Sẵn sàng."
                                       Foreground="#FF334155" FontFamily="Consolas" FontSize="12"
                                       TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Expander>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
