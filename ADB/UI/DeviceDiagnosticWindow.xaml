<Window x:Class="ADB_Tool_Automation_Post_FB.UI.DeviceDiagnosticWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IKAutomation - Farm Control"
        Width="1080" Height="780"
        MinWidth="920" MinHeight="680"
        Background="#FFF4F7FB"
        FontFamily="Segoe UI" FontSize="13"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FF172033"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF64748B"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#FFE2E8F0"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#FF2563EB"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="CaptionStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="#FFCBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FFF8FAFC"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.72"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FFE2E8F0"/>
                                <Setter Property="Foreground" Value="#FF94A3B8"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Foreground" Value="#FF334155"/>
            <Setter Property="Background" Value="#FFF1F5F9"/>
            <Setter Property="Padding" Value="11,6"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <Style x:Key="ContinuousButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#FF0F766E"/>
        </Style>

        <Style x:Key="RetryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#FFD97706"/>
        </Style>

        <Style x:Key="StopButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#FFDC2626"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Infinity Kingdom Farm Control"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="24" FontWeight="Bold"/>
                <TextBlock Text="Quản lý thiết bị, farm liên tục và theo dõi sức khỏe trong một màn hình."
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            <Border Grid.Column="1" Background="#FFDBEAFE" CornerRadius="14"
                    Padding="12,6" VerticalAlignment="Center">
                <TextBlock Text="Tối đa 20 thiết bị" Foreground="#FF1D4ED8"
                           FontWeight="SemiBold"/>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="410"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Thiết bị" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Chọn các LDPlayer sẽ tham gia phiên chạy."
                                               Style="{StaticResource CaptionStyle}" Margin="0,3,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Làm mới"
                                        Click="RefreshDevices_Click"
                                        Style="{StaticResource SecondaryButtonStyle}"/>
                            </Grid>

                            <ListBox x:Name="DeviceSelectionListBox" Height="210"
                                     BorderThickness="0" Background="Transparent"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FFF8FAFC" BorderBrush="#FFE2E8F0"
                                                BorderThickness="1" CornerRadius="6"
                                                Padding="10,8" Margin="0,3">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox IsChecked="{Binding IsSelected}"
                                                          Content="{Binding DeviceName}"
                                                          FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Status}"
                                                           Foreground="#FF475569"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="145"
                                                           ToolTip="{Binding Status}"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <WrapPanel Margin="0,10,0,0">
                                <Button Content="Chọn tất cả" Click="SelectAllDevices_Click"
                                        Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                                <Button Content="Bỏ chọn" Click="ClearDeviceSelection_Click"
                                        Style="{StaticResource SecondaryButtonStyle}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border x:Name="OneShotFarmResourcesGroupBox"
                            Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Cấu hình farm" Style="{StaticResource CardTitleStyle}"/>
                            <TextBlock Text="Chọn ít nhất hai loại tài nguyên để hệ thống luân phiên."
                                       Style="{StaticResource CaptionStyle}" Margin="0,3,0,12"/>
                            <WrapPanel Margin="0,0,0,10">
                                <CheckBox x:Name="IronResourceCheckBox" Content="Sắt" Margin="0,0,18,8"/>
                                <CheckBox x:Name="StoneResourceCheckBox" Content="Mỏ đá" Margin="0,0,18,8"/>
                                <CheckBox x:Name="WoodResourceCheckBox" Content="Rừng" Margin="0,0,18,8"/>
                                <CheckBox x:Name="FoodResourceCheckBox" Content="Đất nông nghiệp" Margin="0,0,0,8"/>
                            </WrapPanel>
                            <CheckBox x:Name="UnoccupiedOnlyCheckBox"
                                      Content="Chỉ mục tiêu chưa có người khai thác" Margin="0,0,0,10"/>

                            <Expander Header="Thiết lập nâng cao" IsExpanded="False"
                                      Foreground="{StaticResource TextPrimaryBrush}">
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="155"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Ưu tiên cấp" Style="{StaticResource CaptionStyle}"/>
                                    <TextBox x:Name="LevelPriorityTextBox" Grid.Row="0" Grid.Column="1"
                                             Text="7,6,5" Style="{StaticResource InputStyle}" Margin="0,0,0,6"/>
                                    <TextBlock Grid.Row="1" Text="Ưu tiên đội" Style="{StaticResource CaptionStyle}"/>
                                    <TextBox x:Name="TeamPriorityTextBox" Grid.Row="1" Grid.Column="1"
                                             Text="4,3,2" Style="{StaticResource InputStyle}" Margin="0,0,0,6"/>
                                    <TextBlock Grid.Row="2" Text="Kiểm tra mỗi (phút)" Style="{StaticResource CaptionStyle}"/>
                                    <TextBox x:Name="ReadyCheckIntervalTextBox" Grid.Row="2" Grid.Column="1"
                                             Text="15" Style="{StaticResource InputStyle}" Margin="0,0,0,6"/>
                                    <TextBlock Grid.Row="3" Text="Dừng chờ sau (giờ)" Style="{StaticResource CaptionStyle}"/>
                                    <TextBox x:Name="ReadyMaxWaitTextBox" Grid.Row="3" Grid.Column="1"
                                             Text="12" Style="{StaticResource InputStyle}"/>
                                    <CheckBox x:Name="AllowTeam1CheckBox" Grid.Row="4" Grid.ColumnSpan="2"
                                              Content="Cho phép Team1" Margin="0,10,0,0"/>
                                </Grid>
                            </Expander>

                            <WrapPanel Margin="0,12,0,0">
                                <Button Content="Lưu cấu hình" Click="SaveFarmSettings_Click"
                                        Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                                <Button Content="Khôi phục mặc định" Click="RestoreFarmDefaults_Click"
                                        Style="{StaticResource SecondaryButtonStyle}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Button x:Name="RunOneShotFarmButton" Content="Chạy thiết bị đã chọn"
                                Click="RunOneShotFarm_Click" Style="{StaticResource BaseButtonStyle}"/>
                        <Button x:Name="RunContinuousFarmButton" Grid.Column="2" Content="Chạy liên tục"
                                Click="RunContinuousFarm_Click" Style="{StaticResource ContinuousButtonStyle}"/>
                        <Button x:Name="RetryFailedDevicesButton" Grid.Row="2" Content="Chạy lại thiết bị lỗi"
                                Click="RetryFailedDevices_Click" Style="{StaticResource RetryButtonStyle}"
                                IsEnabled="False"/>
                        <Button x:Name="StopOneShotFarmButton" Grid.Row="2" Grid.Column="2" Content="Dừng"
                                Click="StopOneShotFarm_Click" Style="{StaticResource StopButtonStyle}"
                                IsEnabled="False"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="180"/>
                </Grid.RowDefinitions>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Sức khỏe hệ thống" Style="{StaticResource CardTitleStyle}"/>
                            <Border Grid.Column="1" Background="#FFEFF6FF" CornerRadius="10" Padding="9,4">
                                <TextBlock x:Name="HealthOverviewTextBlock" Text="Idle"
                                           Foreground="#FF1D4ED8" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="135"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="125"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/><RowDefinition Height="28"/>
                                <RowDefinition Height="28"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Trạng thái thiết bị" Style="{StaticResource CaptionStyle}"/>
                            <TextBlock x:Name="HealthStatesTextBlock" Grid.Row="0" Grid.Column="1"
                                       Text="-" Style="{StaticResource ValueStyle}" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Lỗi / ổ đĩa" Style="{StaticResource CaptionStyle}"/>
                            <TextBlock x:Name="HealthPressureTextBlock" Grid.Row="0" Grid.Column="3"
                                       Text="-" Style="{StaticResource ValueStyle}"/>
                            <TextBlock Grid.Row="1" Text="Tải thích ứng" Style="{StaticResource CaptionStyle}"/>
                            <TextBlock x:Name="HealthLoadTextBlock" Grid.Row="1" Grid.Column="1"
                                       Text="-" Style="{StaticResource ValueStyle}"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Uptime" Style="{StaticResource CaptionStyle}"/>
                            <TextBlock x:Name="HealthUptimeTextBlock" Grid.Row="1" Grid.Column="3"
                                       Text="00:00:00" Style="{StaticResource ValueStyle}"/>
                            <TextBlock Grid.Row="2" Text="Heartbeat gần nhất" Style="{StaticResource CaptionStyle}"/>
                            <TextBlock x:Name="HealthHeartbeatTextBlock" Grid.Row="2" Grid.Column="1"
                                       Grid.ColumnSpan="3" Text="-" Style="{StaticResource ValueStyle}"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Tiến trình farm" Style="{StaticResource CardTitleStyle}"/>
                            <Border Grid.Column="1" Background="#FFEFF6FF" CornerRadius="10" Padding="9,4">
                                <TextBlock x:Name="ProgressStageTextBlock" Text="Idle"
                                           Foreground="#FF1D4ED8" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>

                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/><RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/><RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/><RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/><RowDefinition Height="30"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Thông báo" Style="{StaticResource CaptionStyle}"/>
                                <TextBlock x:Name="ProgressMessageTextBlock" Grid.Row="0" Grid.Column="1"
                                           Text="-" Style="{StaticResource ValueStyle}" TextWrapping="Wrap"
                                           Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="1" Text="Số lần kiểm tra" Style="{StaticResource CaptionStyle}"/>
                                <TextBlock x:Name="ProgressChecksTextBlock" Grid.Row="1" Grid.Column="1" Text="0" Style="{StaticResource ValueStyle}"/>
                                <TextBlock Grid.Row="2" Text="Đội được phép" Style="{StaticResource CaptionStyle}"/>
                                <TextBlock x:Name="ProgressAllowedTeamsTextBlock" Grid.Row="2" Grid.Column="1" Text="-" Style="{StaticResource ValueStyle}"/>
                                <TextBlock Grid.Row="3" Text="Đội sẵn sàng" Style="{StaticResource CaptionStyle}"/>
                                <TextBlock x:Name="ProgressReadyTeamsTextBlock" Grid.Row="3" Grid.Column="1" Text="-" Style="{StaticResource ValueStyle}"/>
                                <TextBlock Grid.Row="4" Text="Đội có thể chọn" Style="{StaticResource CaptionStyle}"/>
                                <TextBlock x:Name="ProgressEligibleTeamsTextBlock" Grid.Row="4" Grid.Column="1" Text="-" Style="{StaticResource ValueStyle}"/>
                                <TextBlock Grid.Row="5" Text="Lần kiểm tra tiếp theo" Style="{StaticResource CaptionStyle}"/>
                                <TextBlock x:Name="ProgressNextCheckTextBlock" Grid.Row="5" Grid.Column="1" Text="-" Style="{StaticResource ValueStyle}"/>
                                <TextBlock Grid.Row="6" Text="Đếm ngược" Style="{StaticResource CaptionStyle}"/>
                                <TextBlock x:Name="ProgressCountdownTextBlock" Grid.Row="6" Grid.Column="1" Text="00:00" Style="{StaticResource ValueStyle}"/>
                                <TextBlock Grid.Row="7" Text="Thời gian chờ còn lại" Style="{StaticResource CaptionStyle}"/>
                                <TextBlock x:Name="ProgressWaitRemainingTextBlock" Grid.Row="7" Grid.Column="1" Text="00:00:00" Style="{StaticResource ValueStyle}"/>
                                <TextBlock Grid.Row="8" Text="Bước hiện tại" Style="{StaticResource CaptionStyle}"/>
                                <TextBlock x:Name="ProgressCurrentStepTextBlock" Grid.Row="8" Grid.Column="1" Text="-" Style="{StaticResource ValueStyle}"/>
                                <TextBlock Grid.Row="9" Text="Tài nguyên / cấp / đội" Style="{StaticResource CaptionStyle}"/>
                                <TextBlock x:Name="ProgressCurrentContextTextBlock" Grid.Row="9" Grid.Column="1"
                                           Text="-" Style="{StaticResource ValueStyle}" TextWrapping="Wrap"/>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Grid.Row="4" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Chi tiết lần chạy gần nhất" Style="{StaticResource CardTitleStyle}"/>
                        <ScrollViewer Grid.Row="2" MaxHeight="220" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="StatusTextBlock" Text="Sẵn sàng."
                                       Foreground="#FF334155" FontFamily="Consolas" FontSize="12"
                                       TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
