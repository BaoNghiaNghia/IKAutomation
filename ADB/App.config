<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8.1" />
	</startup>

	<appSettings>
		<!-- Đường dẫn API gốc -->
		<add key="API_BASE_URL" value="https://boostgamemobile.com/service" />

		<!-- Đường dẫn tới LDConsole -->
		<add key="LDCONSOLE_PATH" value="D:\LDPlayer\LDPlayer9\ldconsole.exe" />

		<!-- Infinity Kingdom diagnostic settings. PackageName must be configured before Launch Game. -->
		<add key="InfinityKingdom.PackageName" value="" />
		<add key="InfinityKingdom.ExpectedWidth" value="1280" />
		<add key="InfinityKingdom.ExpectedHeight" value="720" />
		<add key="InfinityKingdom.Language" value="vi" />
		<add key="Diagnostics.ScreenshotDirectory" value="Diagnostics/Screenshots" />

		<!-- Basic game-state detector settings -->
		<add key="GameDetection.ExpectedWidth" value="1280" />
		<add key="GameDetection.ExpectedHeight" value="720" />
		<add key="GameDetection.RequireExpectedResolution" value="true" />
		<add key="GameDetection.SaveUnknownScreenshots" value="true" />
		<add key="GameDetection.UnknownScreenshotDirectory" value="Diagnostics/UnknownStates" />

		<!-- Verified WorldMap navigation settings -->
		<add key="WorldMapNavigation.StatePollIntervalMs" value="400" />
		<add key="WorldMapNavigation.StateTransitionTimeoutSeconds" value="8" />
		<add key="WorldMapNavigation.MaxOpenSearchAttempts" value="2" />
	</appSettings>
</configuration>
