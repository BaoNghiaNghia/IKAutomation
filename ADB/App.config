<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8.1" />
	</startup>

	<appSettings>
		<!-- Đường dẫn tới LDConsole -->
		<add key="LDCONSOLE_PATH" value="C:\LDPlayer\LDPlayer9\ldconsole.exe" />

		<!-- Infinity Kingdom diagnostic settings. Override PackageName when using a regional build. -->
		<add key="InfinityKingdom.PackageName" value="com.gtarcade.ioe.global" />
		<add key="InfinityKingdom.ExpectedWidth" value="1280" />
		<add key="InfinityKingdom.ExpectedHeight" value="720" />
		<add key="InfinityKingdom.Language" value="vi" />
		<add key="Diagnostics.ScreenshotDirectory" value="Diagnostics/Screenshots" />
		<!-- Continuous-operation retention and disk-pressure protection. -->
		<add key="Operations.DiagnosticRootDirectory" value="Diagnostics" />
		<add key="Operations.MaintenanceIntervalMinutes" value="5" />
		<add key="Operations.ScreenshotRetentionDays" value="14" />
		<add key="Operations.MaximumDiagnosticBytes" value="5368709120" />
		<add key="Operations.MinimumFreeDiskBytes" value="10737418240" />
		<add key="Operations.ResumeFreeDiskBytes" value="12884901888" />
		<add key="Operations.LogRotationBytes" value="20971520" />
		<add key="Operations.LogRetentionDays" value="30" />
		<!-- Adaptive shared load gate. Hard maximum remains 20 devices. -->
		<add key="Operations.AdaptiveMinimumConcurrency" value="4" />
		<add key="Operations.AdaptiveInitialConcurrency" value="6" />
		<add key="Operations.AdaptiveMaximumConcurrency" value="20" />
		<add key="Operations.AdaptiveSampleIntervalMs" value="5000" />
		<add key="Operations.AdaptiveHealthySamplesToIncrease" value="3" />
		<add key="Operations.AdaptiveHighCpuPercent" value="88" />
		<add key="Operations.AdaptiveLowAvailableMemoryBytes" value="2147483648" />
		<add key="Operations.AdaptiveHighTechnicalFailureRate" value="0.25" />
		<add key="Operations.AdaptiveObservationWindowSize" value="20" />
		<add key="Operations.AdaptiveHighPreflightLatencyMs" value="30000" />
		<add key="Operations.AutomationStaggerMinMs" value="2000" />
		<add key="Operations.AutomationStaggerMaxMs" value="10000" />
		<add key="Operations.RecoveryStaggerMinMs" value="30000" />
		<add key="Operations.RecoveryStaggerMaxMs" value="60000" />

		<!-- Basic game-state detector settings -->
		<add key="GameDetection.ExpectedWidth" value="1280" />
		<add key="GameDetection.ExpectedHeight" value="720" />
		<add key="GameDetection.RequireExpectedResolution" value="true" />
		<add key="GameDetection.SaveUnknownScreenshots" value="true" />
		<add key="GameDetection.UnknownScreenshotDirectory" value="Diagnostics/UnknownStates" />

		<!-- Verified WorldMap navigation settings -->
		<add key="WorldMapNavigation.StatePollIntervalMs" value="400" />
		<add key="WorldMapNavigation.StateTransitionTimeoutSeconds" value="8" />
		<add key="WorldMapNavigation.MaxOpenSearchAttempts" value="2" />

		<!-- Verified resource-search configuration settings -->
		<add key="ResourceSearchConfiguration.StatePollIntervalMs" value="300" />
		<add key="ResourceSearchConfiguration.ActionVerificationTimeoutSeconds" value="5" />
		<add key="ResourceSearchConfiguration.MaxSelectionAttempts" value="2" />
		<add key="ResourceSearchConfiguration.MinimumLevel" value="1" />
		<add key="ResourceSearchConfiguration.MaximumLevel" value="30" />
		<add key="ResourceSearchConfiguration.ResetMinusTapCount" value="30" />
		<add key="ResourceSearchConfiguration.TapIntervalMs" value="150" />

		<!-- Execute Search and verify transient/result outcomes -->
		<add key="ResourceSearchExecution.NotFoundObservationWindowMs" value="4000" />
		<add key="ResourceSearchExecution.NotFoundFastPollIntervalMs" value="120" />
		<add key="ResourceSearchExecution.NormalPollIntervalMs" value="300" />
		<add key="ResourceSearchExecution.SearchResultTimeoutSeconds" value="10" />
		<add key="ResourceSearchExecution.MaxSearchTapAttempts" value="2" />
		<add key="ResourceSearchExecution.SearchTapVerificationTimeoutSeconds" value="3" />
		<add key="ResourceSearchExecution.ToastRegion.X" value="150" />
		<add key="ResourceSearchExecution.ToastRegion.Y" value="120" />
		<add key="ResourceSearchExecution.ToastRegion.Width" value="980" />
		<add key="ResourceSearchExecution.ToastRegion.Height" value="400" />
		<add key="ResourceSearchExecution.MaxToastAnchorVerticalDistancePx" value="140" />
		<add key="ResourceSearchExecution.CameraMovementThreshold" value="0.04" />
		<add key="ResourceSearchExecution.CameraStableThreshold" value="0.015" />
		<add key="ResourceSearchExecution.RequiredStableFrames" value="3" />
		<add key="ResourceSearchExecution.MaxTransientUnknownFrames" value="5" />
		<add key="ResourceSearchExecution.SaveResultScreenshots" value="true" />
		<add key="ResourceSearchExecution.SaveObservationBurst" value="false" />
		<add key="ResourceSearchExecution.MaxObservationBurstFrames" value="10" />
		<add key="ResourceSearchExecution.ResultScreenshotDirectory" value="Diagnostics/SearchResults" />
		<add key="ResourceSearchExecution.ObservationBurstDirectory" value="Diagnostics/SearchObservation" />
		<add key="ResourceSearchExecution.ExpectedWidth" value="1280" />
		<add key="ResourceSearchExecution.ExpectedHeight" value="720" />
		<add key="ResourceSearchExecution.MapRegion.X" value="160" />
		<add key="ResourceSearchExecution.MapRegion.Y" value="80" />
		<add key="ResourceSearchExecution.MapRegion.Width" value="960" />
		<add key="ResourceSearchExecution.MapRegion.Height" value="440" />

		<!-- Bounded Iron resource-level fallback: Lv7 -> Lv6 -> Lv5 -->
		<add key="ResourceLevelFallback.Levels" value="7,6,5" />
		<add key="ResourceLevelFallback.AttemptsPerLevel" value="1" />
		<add key="ResourceLevelFallback.RequiredConsecutiveToastClearFrames" value="2" />
		<add key="ResourceLevelFallback.ToastClearPollIntervalMs" value="150" />
		<add key="ResourceLevelFallback.ToastClearTimeoutSeconds" value="5" />
		<add key="ResourceLevelFallback.StopOnFirstLocated" value="true" />
		<add key="ResourceLevelFallback.WaitForToastClearBetweenAttempts" value="true" />
		<add key="ResourceLevelFallback.SaveExhaustedScreenshot" value="true" />
		<add key="ResourceLevelFallback.ScreenshotDirectory" value="Diagnostics/ResourceLevelFallback" />

		<!-- Detect and verify the located Iron resource popup; no Gather input is sent. -->
		<add key="ResourcePopupVerification.PollIntervalMs" value="250" />
		<add key="ResourcePopupVerification.VerificationTimeoutSeconds" value="5" />
		<add key="ResourcePopupVerification.RequiredConsecutiveReadyFrames" value="1" />
		<add key="ResourcePopupVerification.HeaderRegion.X" value="450" />
		<add key="ResourcePopupVerification.HeaderRegion.Y" value="230" />
		<add key="ResourcePopupVerification.HeaderRegion.Width" value="680" />
		<add key="ResourcePopupVerification.HeaderRegion.Height" value="310" />
		<add key="ResourcePopupVerification.ActionRegion.X" value="560" />
		<add key="ResourcePopupVerification.ActionRegion.Y" value="430" />
		<add key="ResourcePopupVerification.ActionRegion.Width" value="500" />
		<add key="ResourcePopupVerification.ActionRegion.Height" value="260" />
		<add key="ResourcePopupVerification.SaveFailureScreenshots" value="true" />
		<add key="ResourcePopupVerification.FailureScreenshotDirectory" value="Diagnostics/ResourcePopup" />
		<add key="ResourcePopupVerification.ExpectedWidth" value="1280" />
		<add key="ResourcePopupVerification.ExpectedHeight" value="720" />
		<add key="OpenTeamSelection.PollIntervalMs" value="250" />
		<add key="OpenTeamSelection.TransitionTimeoutSeconds" value="8" />
		<add key="OpenTeamSelection.MaxGatherTapAttempts" value="2" />
		<add key="OpenTeamSelection.GatherTapRetryDelayMs" value="750" />
		<add key="OpenTeamSelection.MaxTransientUnknownFrames" value="5" />
		<add key="OpenTeamSelection.RequiredTeamSelectionSignals" value="2" />
		<add key="OpenTeamSelection.RequireReadyForSuccess" value="true" />
		<add key="OpenTeamSelection.SaveFailureScreenshots" value="true" />
		<add key="OpenTeamSelection.FailureScreenshotDirectory" value="Diagnostics/TeamSelection" />
		<add key="OpenTeamSelection.TeamSelectionRegion.X" value="0" />
		<add key="OpenTeamSelection.TeamSelectionRegion.Y" value="0" />
		<add key="OpenTeamSelection.TeamSelectionRegion.Width" value="780" />
		<add key="OpenTeamSelection.TeamSelectionRegion.Height" value="720" />
		<add key="FarmTeamSelection.AllowedTeams" value="1,2,3,4" />
		<add key="FarmTeamSelection.Priority" value="4,3,2,1" />
		<add key="FarmTeamSelection.AllowTeam1" value="true" />
		<add key="FarmTeamSelection.PollIntervalMs" value="250" />
		<add key="FarmTeamSelection.SelectionTimeoutSeconds" value="6" />
		<add key="FarmTeamSelection.MaxSelectionAttemptsPerTeam" value="2" />
		<add key="FarmTeamSelection.TapRetryDelayMs" value="500" />
		<add key="FarmTeamSelection.SaveFailureScreenshots" value="true" />
		<add key="FarmTeamSelection.FailureScreenshotDirectory" value="Diagnostics/FarmTeamSelection" />
		<add key="FarmTeamSelection.TeamRegions.1.X" value="0" />
		<add key="FarmTeamSelection.TeamRegions.1.Y" value="0" />
		<add key="FarmTeamSelection.TeamRegions.1.Width" value="235" />
		<add key="FarmTeamSelection.TeamRegions.1.Height" value="150" />
		<add key="FarmTeamSelection.TeamRegions.2.X" value="0" />
		<add key="FarmTeamSelection.TeamRegions.2.Y" value="145" />
		<add key="FarmTeamSelection.TeamRegions.2.Width" value="235" />
		<add key="FarmTeamSelection.TeamRegions.2.Height" value="145" />
		<add key="FarmTeamSelection.TeamRegions.3.X" value="0" />
		<add key="FarmTeamSelection.TeamRegions.3.Y" value="290" />
		<add key="FarmTeamSelection.TeamRegions.3.Width" value="235" />
		<add key="FarmTeamSelection.TeamRegions.3.Height" value="145" />
		<add key="FarmTeamSelection.TeamRegions.4.X" value="0" />
		<add key="FarmTeamSelection.TeamRegions.4.Y" value="435" />
		<add key="FarmTeamSelection.TeamRegions.4.Width" value="235" />
		<add key="FarmTeamSelection.TeamRegions.4.Height" value="155" />
		<add key="DispatchSelectedTeam.PollIntervalMs" value="250" />
		<add key="DispatchSelectedTeam.TransitionTimeoutSeconds" value="10" />
		<add key="DispatchSelectedTeam.MaxActionTapAttempts" value="2" />
		<add key="DispatchSelectedTeam.ActionTapRetryDelayMs" value="800" />
		<add key="DispatchSelectedTeam.MaxTransientUnknownFrames" value="5" />
		<add key="DispatchSelectedTeam.RequiredConsecutiveSuccessFrames" value="2" />
		<add key="DispatchSelectedTeam.TeamRegionChangeThreshold" value="0.025" />
		<add key="DispatchSelectedTeam.AllowStructuralVerificationFallback" value="true" />
		<add key="DispatchSelectedTeam.EnableReadyDisappearanceVerification" value="true" />
		<add key="DispatchSelectedTeam.EnableTimerProgressionVerification" value="true" />
		<add key="DispatchSelectedTeam.TimerSampleIntervalMs" value="1000" />
		<add key="DispatchSelectedTeam.MinimumTimerForegroundRatio" value="0.01" />
		<add key="DispatchSelectedTeam.MaximumTimerForegroundRatio" value="0.35" />
		<add key="DispatchSelectedTeam.MinimumTimerDifferenceRatio" value="0.003" />
		<add key="DispatchSelectedTeam.MaximumTimerDifferenceRatio" value="0.25" />
		<add key="DispatchSelectedTeam.TeamTimerRegions.1.X" value="55" />
		<add key="DispatchSelectedTeam.TeamTimerRegions.1.Y" value="310" />
		<add key="DispatchSelectedTeam.TeamTimerRegions.1.Width" value="95" />
		<add key="DispatchSelectedTeam.TeamTimerRegions.1.Height" value="28" />
		<add key="DispatchSelectedTeam.TeamTimerRegions.2.X" value="55" />
		<add key="DispatchSelectedTeam.TeamTimerRegions.2.Y" value="380" />
		<add key="DispatchSelectedTeam.TeamTimerRegions.2.Width" value="95" />
		<add key="DispatchSelectedTeam.TeamTimerRegions.2.Height" value="28" />
		<add key="DispatchSelectedTeam.TeamTimerRegions.3.X" value="55" />
		<add key="DispatchSelectedTeam.TeamTimerRegions.3.Y" value="450" />
		<add key="DispatchSelectedTeam.TeamTimerRegions.3.Width" value="95" />
		<add key="DispatchSelectedTeam.TeamTimerRegions.3.Height" value="28" />
		<add key="DispatchSelectedTeam.TeamTimerRegions.4.X" value="55" />
		<add key="DispatchSelectedTeam.TeamTimerRegions.4.Y" value="520" />
		<add key="DispatchSelectedTeam.TeamTimerRegions.4.Width" value="95" />
		<add key="DispatchSelectedTeam.TeamTimerRegions.4.Height" value="28" />
		<add key="DispatchSelectedTeam.SaveFailureScreenshots" value="true" />
		<add key="DispatchSelectedTeam.FailureScreenshotDirectory" value="Diagnostics/MarchDispatch" />
		<add key="StorageLimitDialog.Policy" value="CancelAndSwitchResource" />
		<add key="StorageLimitDialog.PollIntervalMs" value="200" />
		<add key="StorageLimitDialog.TransitionTimeoutSeconds" value="8" />
		<add key="StorageLimitDialog.MaxCancelAttempts" value="2" />
		<add key="StorageLimitDialog.CancelRetryDelayMs" value="500" />
		<add key="StorageLimitDialog.MaxTransientUnknownFrames" value="5" />
		<add key="StorageLimitDialog.Region.X" value="250" />
		<add key="StorageLimitDialog.Region.Y" value="100" />
		<add key="StorageLimitDialog.Region.Width" value="780" />
		<add key="StorageLimitDialog.Region.Height" value="520" />
		<add key="ResourceFarmFallback.ResourcePriority" value="Iron,Stone,Wood,Food" />
		<add key="ResourceFarmFallback.LevelPriority" value="7,6,5" />
		<add key="ResourceFarmFallback.AttemptsPerLevel" value="1" />
		<add key="ResourceFarmFallback.StorageLimitPolicy" value="CancelAndSwitchResource" />
		<add key="ResourceFarmFallback.MaxBackAttempts" value="1" />
		<add key="ResourceFarmFallback.SwitchOnStorageLimit" value="true" />
		<add key="ResourceFarmFallback.SwitchWhenLevelsExhausted" value="true" />
		<add key="ResourceFarmFallback.MaxRecoveryTransitions" value="3" />
		<add key="ResourceFarmFallback.RecoveryPollIntervalMs" value="250" />
		<add key="ResourceFarmFallback.RecoveryTimeoutSeconds" value="8" />
		<add key="ResourceFarmFallback.StopOnFirstMarchStarted" value="true" />
		<add key="ResourceFarmFallback.SaveAttemptScreenshots" value="true" />
		<add key="ResourceFarmFallback.ScreenshotDirectory" value="Diagnostics/ResourceFarmFallback" />
		<add key="OneShotFarmWorkflow.ResourceType" value="Iron" />
		<add key="OneShotFarmWorkflow.TargetLevel" value="7" />
		<add key="OneShotFarmWorkflow.ResourceLevelPriority" value="7,6,5" />
		<add key="OneShotFarmWorkflow.AttemptsPerResourceLevel" value="1" />
		<add key="OneShotFarmWorkflow.UnoccupiedOnly" value="true" />
		<add key="OneShotFarmWorkflow.AllowedTeams" value="1,2,3,4" />
		<add key="OneShotFarmWorkflow.TeamPriority" value="4,3,2,1" />
		<add key="OneShotFarmWorkflow.AllowTeam1" value="true" />
		<add key="OneShotFarmWorkflow.RequireMarchVerification" value="true" />
		<add key="OneShotFarmWorkflow.SaveStepFailureScreenshots" value="true" />
		<add key="OneShotFarmWorkflow.SaveSuccessScreenshot" value="true" />
		<add key="OneShotFarmWorkflow.ScreenshotDirectory" value="Diagnostics/OneShotFarm" />
		<add key="WorldMapTeamAvailability.TeamRosterRegion.X" value="0" />
		<add key="WorldMapTeamAvailability.TeamRosterRegion.Y" value="270" />
		<add key="WorldMapTeamAvailability.TeamRosterRegion.Width" value="150" />
		<add key="WorldMapTeamAvailability.TeamRosterRegion.Height" value="280" />
		<add key="ReadyTeamGate.CheckIntervalMinutes" value="15" />
		<add key="ReadyTeamGate.MaxWaitHours" value="12" />
		<add key="ReadyTeamGate.NoReadyConfirmations" value="3" />
		<add key="ReadyTeamGate.PostDispatchRecheckDelayMs" value="750" />
	</appSettings>

	<runtime>
		<assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
			<dependentAssembly>
				<assemblyIdentity name="System.Runtime.CompilerServices.Unsafe"
					publicKeyToken="b03f5f7f11d50a3a" culture="neutral" />
				<bindingRedirect oldVersion="0.0.0.0-6.0.0.0" newVersion="6.0.0.0" />
			</dependentAssembly>
		</assemblyBinding>
	</runtime>
</configuration>
